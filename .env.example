# ══════════════════════════════════════════════════════════════
# MI ARCHIVO DE VARIABLES DE ENTORNO
# ══════════════════════════════════════════════════════════════
# INSTRUCCIONES:
#   1. Copia este archivo y renómbralo a exactamente: .env
#   2. Rellena cada valor con tus credenciales reales
#   3. NUNCA subas el archivo .env a GitHub (ya está en .gitignore)
#   4. En Render, configuras estas mismas variables en el panel web

# ──────────────────────────────────────────────────────────────
# MERCADO PAGO
# Dónde las consigo:
#   → mercadopago.com.co → Mis aplicaciones → [Tu app] → Credenciales
# Hay DOS sets: "Credenciales de prueba" y "Credenciales de producción"
# Para empezar a probar usa las de PRUEBA.
# ──────────────────────────────────────────────────────────────

# Mi Access Token de Mercado Pago (el secreto, SOLO va aquí, nunca en el frontend)
# Prueba:      APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000
# Producción:  APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000
MP_ACCESS_TOKEN=PEGAR_AQUI_MI_ACCESS_TOKEN_DE_MP

# Mi llave pública de Mercado Pago (esta SÍ va en el frontend, no es secreta)
# Prueba:      TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Producción:  APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MP_PUBLIC_KEY=PEGAR_AQUI_MI_PUBLIC_KEY_DE_MP

# ──────────────────────────────────────────────────────────────
# URLs DE REDIRECCIÓN
# Dónde llega el usuario después del pago
# En pruebas puedes usar las URLs de Netlify que te dé el deploy
# ──────────────────────────────────────────────────────────────

# URL de mi frontend publicado en Netlify (sin / al final)
# Ejemplo: https://cartas-amor-manu.netlify.app
FRONTEND_URL=https://TU-SITIO.netlify.app

# ──────────────────────────────────────────────────────────────
# CONFIGURACIÓN DEL SERVIDOR
# ──────────────────────────────────────────────────────────────

# Puerto donde corre mi servidor localmente (en Render se ignora, él pone el suyo)
PORT=3000

# Mi clave secreta para validar webhooks de MP (la genero yo, cualquier texto largo)
# Ejemplo: miClaveSecreta2025CaritasAmor
WEBHOOK_SECRET=INVENTAR_UNA_CLAVE_LARGA_Y_SEGURA